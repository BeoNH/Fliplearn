## NetworkManager Implementation Template

```typescript
export class NetworkManager {
  private static _instance: NetworkManager | null = null;
  private readonly BASE_URL = 'https://your-api.example.com';

  static get instance(): NetworkManager {
    if (!NetworkManager._instance) {
      NetworkManager._instance = new NetworkManager();
    }
    return NetworkManager._instance;
  }

  async saveScore(payload: ISaveScoreRequest): Promise<ISaveScoreResponse> {
    try {
      const response = await fetch(`${this.BASE_URL}/api/saveScore`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data: ISaveScoreResponse = await response.json();
      Logger.info('[NetworkManager]', 'saveScore success', data);
      return data;

    } catch (error) {
      Logger.error('[NetworkManager]', 'saveScore failed', error);
      throw error;   // re-throw để caller xử lý UI feedback
    }
  }

  async getLeaderboard(): Promise<ILeaderboardEntry[]> {
    try {
      const response = await fetch(`${this.BASE_URL}/api/leaderboard`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json() as ILeaderboardEntry[];
    } catch (error) {
      Logger.error('[NetworkManager]', 'getLeaderboard failed', error);
      throw error;
    }
  }
}
```

---

## Luồng gọi API trong Game

```
[GameManager.endSession()]
    │
    ├─ ScoreManager.calcFinalScore() → score, time
    │
    ├─ NetworkManager.saveScore({ score, time, topicId })
    │       ├─ success → UIManager.showResult(data)
    │       └─ error   → UIManager.showResult(data) + show offline notice
    │
    └─ ScoreManager.updateLocalBest(topicId, score) ← luôn update local
```

---

## Error Handling Policy

| Trường hợp | Hành động |
|---|---|
| Network timeout | Retry 1 lần, nếu fail → hiển thị offline mode |
| HTTP 4xx | Log error, hiển thị thông báo user-friendly |
| HTTP 5xx | Log error, retry sau 2 giây |
| Parse error | Log error, dùng fallback data |

```typescript
// Không để UI bị block khi API fail
// Luôn hiển thị màn hình kết quả dù API lỗi
try {
  await NetworkManager.instance.saveScore(payload);
} catch {
  Logger.warn('[GameManager]', 'Score not saved — offline mode');
} finally {
  UIManager.instance.showScreen(ScreenName.RESULT);
}
```
