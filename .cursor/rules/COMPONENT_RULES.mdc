## ResultPanel

```typescript
interface IResultData {
  finalScore: number;
  timeUsed: number;      // giây
  isNewBestScore: boolean;
  totalMatched: number;
  totalPairs: number;
}

@ccclass('ResultPanel')
export class ResultPanel extends Component {
  show(data: IResultData): void {
    // Render result — không tính điểm ở đây
    // Điểm đã được ScoreManager tính và truyền vào
  }

  private _onPlayAgainTap(): void {
    cc.director.emit(ON_PLAY_AGAIN);
  }

  private _onLeaderboardTap(): void {
    UIManager.instance.showScreen(ScreenName.LEADERBOARD);
  }
}
