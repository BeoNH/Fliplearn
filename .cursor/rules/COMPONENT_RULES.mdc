## GameHUD – In-game UI

```typescript
@ccclass('GameHUD')
export class GameHUD extends Component {

  @property(Label) private _timerLabel: Label = null!;
  @property(Label) private _matchCountLabel: Label = null!;

  onLoad(): void {
    cc.director.on(ON_CARD_MATCHED, this._onMatched, this);
    cc.director.on(ON_GAME_TIMEOUT, this._onTimeout, this);
  }

  onDestroy(): void {
    cc.director.off(ON_CARD_MATCHED, this._onMatched, this);
    cc.director.off(ON_GAME_TIMEOUT, this._onTimeout, this);
  }

  updateTimer(remainSeconds: number): void {
    this._timerLabel.string = this._formatTime(remainSeconds);
  }

  private _onMatched(): void {
    // update match count display
  }

  private _formatTime(seconds: number): string {
    const m = Math.floor(seconds / 60).toString().padStart(2, '0');
    const s = (seconds % 60).toString().padStart(2, '0');
    return `${m}:${s}`;
  }
}
```

