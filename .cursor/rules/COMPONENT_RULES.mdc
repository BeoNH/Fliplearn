## Cocos-specific Tips

```typescript
// ✅ Cache node trong onLoad
onLoad(): void {
  this._cardNode = this.node.getChildByName('Card')!;
}

// ❌ Tìm node trong update
update(dt: number): void {
  const card = this.node.find('Card'); // BAD — gọi mỗi frame
}

// ✅ Load prefab qua ResourceManager
ResourceManager.instance.loadPrefab('CardPrefab', (prefab) => {
  const node = instantiate(prefab);
  this.node.addChild(node);
});

// ❌ Load trực tiếp trong component
resources.load('prefabs/CardPrefab', Prefab, ...); // BAD
```
